#include <iostream>
using namespace std

int powerOf2(int n)
{
    int p = 1;

    while(p < n)
    {
        p = p * 2;
    }

    return p;
}

int main()
{
    int memory;
    int n;

    cout << "Enter Total Memory: ";
    cin >> memory;

    cout << "Enter Number of Processes: ";
    cin >> n;

    int process[10];

    cout << "Enter Process Sizes:\n";

    for(int i = 0; i < n; i++)
    {
        cin >> process[i];
    }

    cout << "\nBuddy System Allocation:\n";

    int freeBlock = memory;

    for(int i = 0; i < n; i++)
    {
        int req = powerOf2(process[i]);

        if(req <= freeBlock)
        {
            cout << "Process " << i+1
                 << " (" << process[i] << ") -> Block "
                 << req << endl;

            freeBlock = freeBlock - req;
        }
        else
        {
            cout << "Process " << i+1
                 << " -> Not Allocated" << endl;
        }
    }

    return 0;
}
