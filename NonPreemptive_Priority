#include <iostream>
#include <climits>
using namespace std;

struct Process
{
    int id, at, bt, pr, ct, tat, wt;
};

int main()
{
    int n;

    cout << "Enter number of processes: ";
    cin >> n;

    Process p[10];

    for(int i = 0; i < n; i++)
    {
        p[i].id = i + 1;

        cout << "Enter AT BT PR for P" << i+1 << ": ";
        cin >> p[i].at >> p[i].bt >> p[i].pr;
    }

    bool done[10] = {false};

    int completed = 0;
    int time = 0;

    while(completed < n)
    {
        int idx = -1;
        int highPR = INT_MAX;

        for(int i = 0; i < n; i++)
        {
            if(!done[i] && p[i].at <= time && p[i].pr < highPR)
            {
                highPR = p[i].pr;
                idx = i;
            }
        }

        if(idx == -1)
        {
            time++;
            continue;
        }

        p[idx].ct = time + p[idx].bt;

        p[idx].tat = p[idx].ct - p[idx].at;

        p[idx].wt = p[idx].tat - p[idx].bt;

        time = p[idx].ct;

        done[idx] = true;
        completed++;
    }

    cout << "\nPID\tAT\tBT\tPR\tCT\tTAT\tWT\n";

    for(int i = 0; i < n; i++)
    {
        cout << p[i].id << "\t"
             << p[i].at << "\t"
             << p[i].bt << "\t"
             << p[i].pr << "\t"
             << p[i].ct << "\t"
             << p[i].tat << "\t"
             << p[i].wt << endl;
    }

    return 0;
}
