#include <iostream>
#include <vector>
#include<queue>
using namespace std;

bool check(vector<int> f, int x) {
    for(int i = 0; i < f.size(); i++) {
        if(f[i] == x)
            return true;
    }
    return false;
}

void FIFO(vector<int> pages, int cap)
{
    vector<int> frame;

    queue<int> q;

    int faults = 0;

    for(int i = 0; i < pages.size(); i++)
    {
        if(!check(frame, pages[i]))
        {
            if(frame.size() < cap)
            {
                frame.push_back(pages[i]);
                q.push(pages[i]);
            }
            else
            {
                int old = q.front();
                q.pop();
                for(int j = 0; j < frame.size(); j++)
                {
                    if(frame[j] == old)
                    {
                        frame[j] = pages[i];
                        break;
                    }
                }
                q.push(pages[i]);
            }
            faults++;
        }
    }
    cout << "FIFO Page Faults = "
         << faults << endl;
}

void LRU(vector<int> pages, int cap)
{
    vector<int> frame;

    int faults = 0;

    for(int i = 0; i < pages.size(); i++)
    {
        bool found = false;

        for(int j = 0; j < frame.size(); j++)
        {
            if(frame[j] == pages[i])
            {
                int temp = frame[j];

                frame.erase(frame.begin() + j);

                frame.push_back(temp);

                found = true;

                break;
            }
        }

        if(!found)
        {
            if(frame.size() == cap)
            {
                frame.erase(frame.begin());
            }

            frame.push_back(pages[i]);

            faults++;
        }
    }

    cout << "LRU Page Faults = "
         << faults << endl;
}

void Optimal(vector<int> pages, int cap)
{
    vector<int> frame;

    int faults = 0;

    for(int i = 0; i < pages.size(); i++)
    {

        if(check(frame, pages[i]))
        {
            continue;
        }

        faults++;

        if(frame.size() < cap)
        {
            frame.push_back(pages[i]);
        }
        else
        {
            int index = -1;

            int farthest = -1;

            for(int j = 0; j < frame.size(); j++)
            {
                int nextUse = 1000;

                for(int k = i + 1; k < pages.size(); k++)
                {
                    if(frame[j] == pages[k])
                    {
                        nextUse = k;

                        break;
                    }
                }

                if(nextUse > farthest)
                {
                    farthest = nextUse;

                    index = j;
                }
            }

            frame[index] = pages[i];
        }
    }

    cout << "Optimal Page Faults = "
         << faults << endl;
}


int main() {
    int n, cap;

    cout << "Enter number of pages: ";
    cin >> n;

    vector<int> pages(n);
    cout << "Enter pages: ";
    for(int i = 0; i < n; i++)
        cin >> pages[i];

    cout << "Enter frame size: ";
    cin >> cap;

    FIFO(pages, cap);
    LRU(pages, cap);
    Optimal(pages, cap);

    return 0;
}
