#include <iostream>
using namespace std;

struct Process
{
    int id, at, bt, ct, tat, wt;
};

int main()
{
    int n;
    cout << "Enter number of processes: ";
    cin >> n;

    Process p[10];

    for(int i = 0; i < n; i++)
    {
        p[i].id = i + 1;

        cout << "Enter Arrival Time and Burst Time for P" << i + 1 << ": ";
        cin >> p[i].at >> p[i].bt;
    }

    for(int i = 0; i < n-1; i++)
    {
        for(int j = 0; j < n-i-1; j++)
        {
            if(p[j].at > p[j+1].at)
            {
                swap(p[j], p[j+1]);
            }
        }
    }

    int time = 0;

    for(int i = 0; i < n; i++)
    {
        if(time < p[i].at)
        {
            time = p[i].at;
        }

        p[i].ct = time + p[i].bt;
        p[i].tat = p[i].ct - p[i].at;
        p[i].wt = p[i].tat - p[i].bt;

        time = p[i].ct;
    }

    cout << "\nPID\tAT\tBT\tCT\tTAT\tWT\n";

    for(int i = 0; i < n; i++)
    {
        cout << p[i].id << "\t"
             << p[i].at << "\t"
             << p[i].bt << "\t"
             << p[i].ct << "\t"
             << p[i].tat << "\t"
             << p[i].wt << endl;
    }

    return 0;
}
