#include <iostream>
using namespace std;

void firstFit(int block[], int m, int process[], int n)
{
    int allocation[10];

    for(int i = 0; i < n; i++)
    {
        allocation[i] = -1;
    }

    for(int i = 0; i < n; i++)
    {
        for(int j = 0; j < m; j++)
        {
            if(block[j] >= process[i])
            {
                allocation[i] = j;

                block[j] = block[j] - process[i];

                break;
            }
        }
    }

    cout << "\nFirst Fit:\n";

    for(int i = 0; i < n; i++)
    {
        cout << "Process " << i+1 << " -> ";

        if(allocation[i] != -1)
        {
            cout << "Block " << allocation[i]+1;
        }
        else
        {
            cout << "Not Allocated";
        }

        cout << endl;
    }
}

void nextFit(int block[], int m, int process[], int n)
{
    int allocation[10];

    for(int i = 0; i < n; i++)
    {
        allocation[i] = -1;
    }

    int j = 0;

    for(int i = 0; i < n; i++)
    {
        int count = 0;

        while(count < m)
        {
            if(block[j] >= process[i])
            {
                allocation[i] = j;

                block[j] = block[j] - process[i];
                j = (j + 1) % m;
                break;
            }

            j = (j + 1) % m;

            count++;
        }
    }

    cout << "\nNext Fit:\n";

    for(int i = 0; i < n; i++)
    {
        cout << "Process " << i+1 << " -> ";

        if(allocation[i] != -1)
        {
            cout << "Block " << allocation[i]+1;
        }
        else
        {
            cout << "Not Allocated";
        }

        cout << endl;
    }
}

void bestFit(int block[], int m, int process[], int n)
{
    int allocation[10];

    for(int i = 0; i < n; i++)
    {
        allocation[i] = -1;
    }

    for(int i = 0; i < n; i++)
    {
        int best = -1;

        for(int j = 0; j < m; j++)
        {
            if(block[j] >= process[i])
            {
                if(best == -1 || block[j] < block[best])
                {
                    best = j;
                }
            }
        }

        if(best != -1)
        {
            allocation[i] = best;

            block[best] = block[best] - process[i];
        }
    }

    cout << "\nBest Fit:\n";

    for(int i = 0; i < n; i++)
    {
        cout << "Process " << i+1 << " -> ";

        if(allocation[i] != -1)
        {
            cout << "Block " << allocation[i]+1;
        }
        else
        {
            cout << "Not Allocated";
        }

        cout << endl;
    }
}

void worstFit(int block[], int m, int process[], int n)
{
    int allocation[10];

    for(int i = 0; i < n; i++)
    {
        allocation[i] = -1;
    }

    for(int i = 0; i < n; i++)
    {
        int worst = -1;

        for(int j = 0; j < m; j++)
        {
            if(block[j] >= process[i])
            {
                if(worst == -1 || block[j] > block[worst])
                {
                    worst = j;
                }
            }
        }

        if(worst != -1)
        {
            allocation[i] = worst;

            block[worst] = block[worst] - process[i];
        }
    }

    cout << "\nWorst Fit:\n";

    for(int i = 0; i < n; i++)
    {
        cout << "Process " << i+1 << " -> ";

        if(allocation[i] != -1)
        {
            cout << "Block " << allocation[i]+1;
        }
        else
        {
            cout << "Not Allocated";
        }

        cout << endl;
    }
}


int main()
{
    int m, n;

    cout << "Enter number of blocks: ";
    cin >> m;

    int block[10];

    cout << "Enter block sizes:\n";

    for(int i = 0; i < m; i++)
    {
        cin >> block[i];
    }

    cout << "Enter number of processes: ";
    cin >> n;

    int process[10];

    cout << "Enter process sizes:\n";

    for(int i = 0; i < n; i++)
    {
        cin >> process[i];
    }

    // Separate copies for each algorithm
    int b1[10], b2[10], b3[10], b4[10];

    for(int i = 0; i < m; i++)
    {
        b1[i] = block[i];
        b2[i] = block[i];
        b3[i] = block[i];
        b4[i] = block[i];
    }

    firstFit(b1, m, process, n);

    bestFit(b2, m, process, n);

    worstFit(b3, m, process, n);

    nextFit(b4, m, process, n);

    return 0;
}
